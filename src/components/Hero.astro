<section id="hero">
  <img class="hbg" src="/images/facade_hero4.png" alt="Hamdi Prim façade boutique Villebarou"/>
  <div class="hov"></div>
  <div class="hcw">
    <div class="rv">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
        <span style="color:var(--wh);font-size:.72rem;font-weight:800;letter-spacing:.2em;text-transform:uppercase;">Depuis 1999</span>
        <span style="width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,.45);display:inline-block;"></span>
        <span style="color:#F5C518;letter-spacing:3px;font-size:.78rem;">★★★★★</span>
        <span style="color:rgba(255,255,255,.5);font-size:.7rem;font-weight:500;">4.4 / 5 Google</span>
      </div>
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(2rem,3.4vw,3.2rem);font-weight:800;color:var(--wh);line-height:1.08;margin-bottom:14px;" class="rv d1">
        Fraîcheur &amp; <em style="color:#F5C518;">Saveurs du Monde</em>
      </h1>
      <p style="font-size:1.05rem;font-weight:600;color:rgba(255,255,255,.82);line-height:1.7;letter-spacing:.02em;margin-bottom:0;" class="rv d2">
        Primeur à Villebarou &nbsp;·&nbsp; Fruits &nbsp;·&nbsp; Légumes &nbsp;·&nbsp; Épices &nbsp;·&nbsp; Fruits secs
      </p>
    </div>
    <div style="flex-shrink:0;">
      <a href="#hor" class="bow" style="padding:14px 36px;font-size:.95rem;display:inline-block;">Nous rendre visite</a>
    </div>
  </div>
  <div style="position:absolute;bottom:-2px;left:0;right:0;z-index:4;">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block;width:100%;height:60px;"><path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="#C0392B"/></svg>
  </div>
</section>
