          Suivre sur Instagram
        </a>
      </div>

    </div>
  </div>
</section>

<style>
#rs { background: var(--gp); padding: 80px 20px; }
.rswrap { max-width: 1000px; margin: 0 auto; }
.rstit { text-align: center; margin-bottom: 50px; }
.rssub { color: var(--gr); font-size: .95rem; margin-top: 10px; }
.rscards { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }

.rscard {
  background: white;
  border-radius: 20px;
  padding: 32px;
  box-shadow: 0 8px 40px rgba(0,0,0,.08);
  display: flex;
  flex-direction: column;
  gap: 24px;
  transition: transform .3s ease, box-shadow .3s ease;
}
.rscard:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,0,0,.13); }

.rscard-top { display: flex; align-items: center; gap: 16px; }
.rscard-ico {
  width: 56px; height: 56px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.fb-ico { background: #1877F2; }
.ig-ico { background: linear-gradient(135deg, #f09433, #e6683c 30%, #dc2743 55%, #cc2366 75%, #bc1888); }

.rscard-name { font-weight: 700; font-size: 1rem; color: var(--dk); }
.rscard-followers { font-size: .82rem; color: var(--gr); margin-top: 3px; }

.rscard-body { flex: 1; }
.rscard-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
.rsbadge {
  font-size: .75rem; font-weight: 600; padding: 4px 12px;
  border-radius: 20px; background: var(--gp); color: var(--gr);
}
.rscard-desc { font-size: .88rem; color: var(--gr); line-height: 1.65; }

.rscard-btn {
  display: flex; align-items: center; justify-content: center;
  gap: 10px; padding: 14px 24px; border-radius: 12px;
  font-weight: 600; font-size: .9rem; text-decoration: none;
  transition: opacity .2s ease, transform .2s ease;
}
.rscard-btn:hover { opacity: .9; transform: scale(1.02); }
.fb-btn { background: #1877F2; color: white; }
.ig-btn { background: linear-gradient(135deg, #f09433, #e6683c 30%, #dc2743 55%, #cc2366 75%, #bc1888); color: white; }

@media(max-width:640px) { .rscards { grid-template-columns: 1fr; } }
</style>
