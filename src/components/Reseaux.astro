            <div class="rscard-name">Hamdi Prim' Blois</div>
            <div class="rscard-followers">1 964 abonnés</div>
          </div>
        </div>
        <div class="rscard-body">
          <div class="rscard-tags">
            <span class="rsbadge">Arrivages</span>
            <span class="rsbadge">Promotions</span>
            <span class="rsbadge">Actualités</span>
          </div>
          <p class="rscard-desc">Suivez notre page Facebook pour ne manquer aucun arrivage, promotion ou événement du magasin.</p>
        </div>
        <a href="https://www.facebook.com/hamdiprim/" target="_blank" rel="noopener" class="rscard-btn fb-btn">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
          Suivre sur Facebook
        </a>
      </div>

      <!-- Instagram -->
