<style>
#rs { background: var(--gp); padding: 80px 20px; }
.rswrap { max-width: 1060px; margin: 0 auto; }
.rstit { text-align: center; margin-bottom: 50px; }
.rssub { color: var(--gr); font-size: .95rem; margin-top: 10px; }
.rscards { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; align-items: start; }

.rscard {
  background: white;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 8px 40px rgba(0,0,0,.08);
  display: flex;
  flex-direction: column;
  transition: transform .3s ease, box-shadow .3s ease;
}
.rscard:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,.12); }

.rscard-header {
  display: flex; align-items: center; gap: 10px;
  padding: 14px 20px;
  font-weight: 700; font-size: .95rem; color: white;
  letter-spacing: .3px;
}
.fb-header { background: #1877F2; }
.ig-header { background: linear-gradient(90deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }

.fb-embed { border-top: none; }

/* Instagram preview */
.ig-preview { padding: 20px; }
.ig-profile { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
.ig-avatar {
  width: 52px; height: 52px; border-radius: 50%;
  overflow: hidden; flex-shrink: 0;
  border: 2px solid transparent;
  background: linear-gradient(white,white) padding-box,
              linear-gradient(135deg,#f09433,#bc1888) border-box;
}
.ig-avatar img { width: 100%; height: 100%; object-fit: cover; }
.ig-handle { font-weight: 700; font-size: .95rem; color: #111; }
.ig-bio { font-size: .78rem; color: #666; margin-top: 3px; line-height: 1.4; }
.ig-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px;
  border-radius: 10px; overflow: hidden;
}
.ig-cell { aspect-ratio: 1; overflow: hidden; }
.ig-cell img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s; }
.ig-cell:hover img { transform: scale(1.08); }

.rscard-btn {
  display: flex; align-items: center; justify-content: center;
  gap: 10px; margin: 16px 20px 20px;
  padding: 13px 24px; border-radius: 12px;
  font-weight: 600; font-size: .88rem; text-decoration: none;
  transition: opacity .2s ease, transform .2s ease;
}
.rscard-btn:hover { opacity: .88; transform: scale(1.02); }
.fb-btn { background: #1877F2; color: white; }
.ig-btn { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #bc1888); color: white; }

@media(max-width:680px) { .rscards { grid-template-columns: 1fr; } }
</style>
