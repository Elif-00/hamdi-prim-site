<section id="rs">
  <div class="rswrap">
    <div class="rstit rv">
      <span class="stag">Suivez-nous</span>
      <h2 class="stit rv d1">Restez <em>connectés</em></h2>
      <p class="rssub rv d2">Arrivages, promotions et coulisses du magasin sur nos réseaux.</p>
    </div>
    <div class="rscards">

      <!-- Facebook -->
      <div class="rscard fbcard rv">
        <div class="rscard-top">
          <div class="rscard-ico fb-ico">
            <svg viewBox="0 0 24 24" fill="white" width="28" height="28"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
