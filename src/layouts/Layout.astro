---
import '../styles/global.css';
export interface Props { title?: string; }
const { title = "Hamdi Prim' Blois | Primeur Fruits & Légumes Villebarou" } = Astro.props;
const schema = {
  "@context": "https://schema.org",
  "@type": "GroceryStore",
  "name": "Hamdi Prim' Blois",
  "telephone": "+33254568736",
  "address": { "@type": "PostalAddress", "streetAddress": "323 Route de Vendôme", "addressLocality": "Villebarou", "postalCode": "41000", "addressCountry": "FR" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.4", "reviewCount": "350" },
  "foundingDate": "1999"
};
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>{title}</title>
<meta name="description" content="Hamdi Prim' Blois — votre primeur de confiance à Villebarou depuis 1999. Fruits, légumes, fruits secs, légumes secs et épices du monde."/>
<meta name="keywords" content="primeur Blois, primeur Villebarou, fruits légumes Blois, marché frais Blois, épices Blois"/>
<meta name="robots" content="index, follow"/>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600;0,700;0,800;0,900;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet"/>
</head>
<body>
<slot />
</body>
</html>
